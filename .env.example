NODE_ENV=development
PORT=4000
API_PREFIX=api/v1
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/finance_saas?schema=public
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=replace-with-long-secret
JWT_REFRESH_SECRET=replace-with-long-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
APP_URL=http://localhost:3000
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=finance-attachments
S3_ACCESS_KEY=minio
S3_SECRET_KEY=miniosecret
S3_FORCE_PATH_STYLE=true
MAX_ATTACHMENT_SIZE_BYTES=5242880
CORS_ORIGINS=http://localhost:3000
